# ─────────────────────────────────────────────────────────────────────────────
# VeriFIR — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/verifir
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/verifir
MONGODB_URI=your-mongodb-uri-here

# ── Pinata (IPFS) ─────────────────────────────────────────────────────────────
# Create a free account at https://app.pinata.cloud
# Go to API Keys → New Key → check pinFileToIPFS + pinJSONToIPFS
PINATA_API_KEY=your-pinata-api-key-here
PINATA_SECRET_KEY=your-pinata-secret-key-here

# ── Sepolia Blockchain ─────────────────────────────────────────────────────────
# RPC endpoint from a provider like Alchemy or Infura
RPC_URL=your-sepolia-rpc-url-here
CONTRACT_ADDRESS=your-deployed-firregistry-contract-address-here
NEXT_PUBLIC_CONTRACT_ADDRESS=your-deployed-firregistry-contract-address-here
CONTRACT_DEPLOY_BLOCK=your-contract-deploy-block-number-here

# Signer wallet private keys — must be pre-authorised on the deployed contract
DEPLOYER_PRIVATE_KEY=your-deployer-private-key-here
POLICE_SIGNER_PRIVATE_KEY=your-police-private-key-here
CITIZEN_SIGNER_PRIVATE_KEY=your-citizen-private-key-here

# ── Session Security ──────────────────────────────────────────────────────────
# Generate a random 32+ char string
SESSION_SECRET=your-random-session-secret-here

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank/commented to disable email notifications silently.
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Generate an App Password for "Mail"
#   4. Use that 16-char password as SMTP_PASS (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="VeriFIR <noreply@verifir.in>"
